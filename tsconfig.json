{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "types": ["bun-types"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "outDir": "dist",
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
